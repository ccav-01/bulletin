---
layout: base.njk
pagination:
  data: previousBulletins
  size: 1
  alias: archivedBulletin
permalink: "previous/{{ archivedBulletin.date }}/"
eleventyComputed:
  title: "{{ archivedBulletin.date | readableDate }}"
---

{% set bulletin = archivedBulletin %}

<header class="bulletin-hero">
  <div class="bulletin-hero__inner">
    <img src="/assets/ccav-badge-white.png" alt="" aria-hidden="true" class="bulletin-hero__badge" />
    <span class="bulletin-hero__date">{{ bulletin.date | readableDate }}</span>
    <h1>{{ bulletin.theme }}</h1>
    {% if bulletin.welcomeMessage %}
    <p class="bulletin-hero__welcome">{{ bulletin.welcomeMessage }}</p>
    {% endif %}
    <div style="margin-top:1rem;">
      <a href="/previous/" class="btn btn--outline" style="color:#fff; border-color:rgba(255,255,255,0.5);">
        ← All Bulletins
      </a>
    </div>
  </div>
</header>

{% set sectionOrder = bulletin.sectionOrder or ["service", "scripture", "announcements", "savetheDates", "thisWeek"] %}

<div class="bulletin-layout" style="grid-template-columns: 1fr;">
  <div class="bulletin-sections">
    {% for section in sectionOrder %}
      {% if section === "service" %}
        {% include "sections/service.njk" %}
      {% elif section === "scripture" and bulletin.scriptureEnabled !== false %}
        {% include "sections/scripture.njk" %}
      {% elif section === "announcements" and bulletin.announcementsEnabled !== false %}
        {% include "sections/announcements.njk" %}
      {% elif section === "savetheDates" and bulletin.savetheDates and bulletin.savetheDates.length and bulletin.savetheDatesEnabled !== false %}
        {% include "sections/savedates.njk" %}
      {% elif section === "thisWeek" and bulletin.thisWeek and bulletin.thisWeek.length and bulletin.thisWeekEnabled !== false %}
        {% include "sections/thisweek.njk" %}
      {% endif %}
    {% endfor %}

    {% if bulletin.giving and bulletin.giving.url %}
    <section class="section-card giving-card" aria-label="Online Giving">
      <div class="giving-card__divider">
        <img src="/assets/dove-paper.png" alt="" aria-hidden="true" />
      </div>
      <p class="giving-card__text">
        Thank you for your generosity and faithful support of this ministry. Your giving enables us to serve our community and proclaim the Word.
      </p>
      <a href="{{ bulletin.giving.url }}" target="_blank" rel="noopener" class="btn btn--ochre">
        {{ bulletin.giving.text or "Give Online" }}
      </a>
    </section>
    {% endif %}
  </div>
</div>
