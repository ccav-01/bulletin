{% set sectionMeta = {
  "service":       { id: "service",       label: "Service",        icon: "map-pin"        },
  "scripture":     { id: "scripture",     label: "Message",        icon: "book-open"      },
  "announcements": { id: "announcements", label: "Announcements",  icon: "megaphone"      },
  "savetheDates":  { id: "savedates",     label: "Save the Dates", icon: "calendar-check" },
  "thisWeek":      { id: "thisweek",      label: "This Week",      icon: "list-checks"    }
} %}

<nav class="toc-mobile" aria-label="Jump to section">
  <ul class="toc-mobile__list" role="list">
    {% for key in sectionOrder %}
      {% set meta = sectionMeta[key] %}
      {% if meta %}
        {% if key === "service"
           or (key === "scripture" and bulletin.scriptureEnabled !== false)
           or (key === "announcements" and bulletin.announcementsEnabled !== false)
           or (key === "savetheDates" and bulletin.savetheDates and bulletin.savetheDates.length and bulletin.savetheDatesEnabled !== false)
           or (key === "thisWeek" and bulletin.thisWeek and bulletin.thisWeek.length and bulletin.thisWeekEnabled !== false) %}
        <li>
          <a href="#{{ meta.id }}" class="toc-mobile__link" data-toc-target="{{ meta.id }}">
            <i data-lucide="{{ meta.icon }}"></i>
            {{ meta.label }}
          </a>
        </li>
        {% endif %}
      {% endif %}
    {% endfor %}
  </ul>
</nav>

<script>
(function () {
  const targets = document.querySelectorAll('[data-toc-target]');
  if (!targets.length || !('IntersectionObserver' in window)) return;

  const sectionIds = [...new Set([...targets].map(el => el.dataset.tocTarget))];
  const sections = sectionIds.map(id => document.getElementById(id)).filter(Boolean);

  function setActive(id) {
    targets.forEach(link => {
      link.classList.toggle('is-active', link.dataset.tocTarget === id);
    });
  }

  const observer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) { setActive(entry.target.id); break; }
      }
    },
    { rootMargin: '-10% 0px -60% 0px', threshold: 0 }
  );

  sections.forEach(s => observer.observe(s));

  targets.forEach(link => {
    link.addEventListener('click', e => {
      e.preventDefault();
      const target = document.getElementById(link.dataset.tocTarget);
      if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });
})();
</script>
