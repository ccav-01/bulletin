<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{% if title %}{{ title }} — {% endif %}Calvary Chapel AV Weekly Bulletin</title>
  <meta name="description" content="Weekly bulletin for Calvary Chapel Antelope Valley — Lancaster, CA" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="icon" type="image/png" href="/assets/dove-ink.png" />
  <link rel="stylesheet" href="/css/styles.css" />
  <style>
    :root {
      --logo-h: {{ bulletin.appearance.logoDesktop or 38 }}px;
      --logo-h-mobile: {{ bulletin.appearance.logoMobile or 32 }}px;
      --badge-h: {{ bulletin.appearance.badgeDesktop or 100 }}px;
      --badge-h-mobile: {{ bulletin.appearance.badgeMobile or 80 }}px;
    }
  </style>
  <script src="/assets/js/lucide.min.js" defer></script>
  <script>document.addEventListener('DOMContentLoaded', () => lucide.createIcons());</script>
</head>
<body>

  <header class="site-header" role="banner">
    <div class="site-header__inner">
      <a href="/" class="site-header__logo" aria-label="Calvary Chapel Antelope Valley — home">
        <img src="/assets/ccav-wordmark-white.png" alt="Calvary Chapel Antelope Valley" />
      </a>
      <nav class="site-header__nav" aria-label="Site navigation">
        <a href="/">This Week</a>
        <a href="/previous/">Past Bulletins</a>
        {% if bulletin.giving and bulletin.giving.url %}
        <a href="{{ bulletin.giving.url }}" target="_blank" rel="noopener" class="btn btn--ochre">Give</a>
        {% endif %}
      </nav>
    </div>
  </header>

  <main id="main-content">
    {{ content | safe }}
  </main>

  <footer class="site-footer" role="contentinfo">
    <div class="site-footer__inner">
      <a href="/" aria-label="Calvary Chapel Antelope Valley — home">
        <img src="/assets/ccav-wordmark-white.png" alt="Calvary Chapel Antelope Valley" class="site-footer__logo" />
      </a>

      <div class="site-footer__address">
        1661 W Lancaster Blvd., Lancaster, CA 93534
      </div>

      <nav class="site-footer__contact" aria-label="Contact information">
        {% if bulletin.contact.phone %}
        <a href="tel:{{ bulletin.contact.phone }}">{{ bulletin.contact.phone }}</a>
        {% endif %}
        {% if bulletin.contact.email %}
        <a href="mailto:{{ bulletin.contact.email }}">{{ bulletin.contact.email }}</a>
        {% endif %}
        {% if bulletin.contact.website %}
        <a href="{{ bulletin.contact.website }}" target="_blank" rel="noopener">calvarychapelav.org</a>
        {% endif %}
      </nav>

      <p class="site-footer__copy">
        Calvary Chapel Antelope Valley &mdash; Acts 2:42
      </p>
    </div>
  </footer>

</body>
</html>
