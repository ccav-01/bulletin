<section id="scripture" class="section-card" aria-labelledby="scripture-heading">
  <div class="section-card__header">
    <div class="section-card__icon">
      <i data-lucide="book-open"></i>
    </div>
    <h2 class="section-card__title" id="scripture-heading">This Week's Message</h2>
  </div>

  <div class="scripture-block">
    <p class="scripture-verse">"{{ bulletin.scripture.verse }}"</p>
    <cite class="scripture-reference">— {{ bulletin.scripture.reference }}</cite>
  </div>

  {% if bulletin.scripture.sermonTitle or bulletin.scripture.sermonSeries %}
  <div class="sermon-info">
    {% if bulletin.scripture.imageUrl %}
    <div class="item-image item-image--1x1">
      <img src="{{ bulletin.scripture.imageUrl }}" alt="{{ bulletin.scripture.sermonSeries or bulletin.scripture.sermonTitle }}" loading="lazy" />
    </div>
    {% endif %}
    {% if bulletin.scripture.sermonTitle %}
    <div>
      <span class="sermon-label">Sermon</span>
      <div class="sermon-title">{{ bulletin.scripture.sermonTitle }}</div>
    </div>
    {% endif %}
    {% if bulletin.scripture.sermonSeries %}
    <span class="sermon-series">{{ bulletin.scripture.sermonSeries }}</span>
    {% endif %}
  </div>
  {% endif %}
</section>
