<section id="events" class="section-card" aria-labelledby="events-heading">
  <div class="section-card__header">
    <div class="section-card__icon" aria-hidden="true">📅</div>
    <h2 class="section-card__title" id="events-heading">Upcoming Events</h2>
  </div>

  {% if bulletin.events and bulletin.events.length %}
  <ul class="events-list">
    {% for event in bulletin.events %}
    {% set eventDate = event.date + "T12:00:00" %}
    <li class="event-item">
      <div class="event-item__date-block">
        <span class="event-item__month">{{ event.date | readableDate | truncate(3, false, '') | upper }}</span>
        <span class="event-item__day">{{ event.date.split('-')[2] | int }}</span>
      </div>
      <div class="event-item__content">
        <div class="event-item__title">{{ event.title }}</div>
        {% if event.time %}
        <div class="event-item__time">🕐 {{ event.time }}</div>
        {% endif %}
        {% if event.description %}
        <p class="event-item__desc">{{ event.description }}</p>
        {% endif %}
      </div>
    </li>
    {% endfor %}
  </ul>
  {% else %}
  <p style="color: var(--color-text-muted); font-style: italic;">No upcoming events.</p>
  {% endif %}
</section>
