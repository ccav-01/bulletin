<section id="service" class="section-card" aria-labelledby="service-heading">
  <div class="section-card__header">
    <div class="section-card__icon" aria-hidden="true">⛪</div>
    <h2 class="section-card__title" id="service-heading">Service Info</h2>
  </div>

  <div class="service-grid">
    <div class="service-item">
      <div class="service-item__label">Service Times</div>
      <div class="service-times">
        {% for time in bulletin.service.times %}
          <span class="service-time-chip">{{ time }}</span>
        {% endfor %}
      </div>
    </div>

    {% if bulletin.service.pastor %}
    <div class="service-item">
      <div class="service-item__label">Pastor</div>
      <div class="service-item__value">{{ bulletin.service.pastor }}</div>
    </div>
    {% endif %}

    {% if bulletin.service.address %}
    <div class="service-item">
      <div class="service-item__label">Location</div>
      <div class="service-item__value">{{ bulletin.service.address }}</div>
    </div>
    {% endif %}
  </div>

  {% if bulletin.service.livestream %}
  <div class="service-livestream">
    <a href="{{ bulletin.service.livestream }}" target="_blank" rel="noopener" class="btn btn--primary">
      📺 Watch Live Online
    </a>
  </div>
  {% endif %}
</section>
