{% set tocSections = [
  { id: "service",       label: "Service Info",  icon: "map-pin"  },
  { id: "scripture",     label: "Message",       icon: "book-open" },
  { id: "announcements", label: "Announcements", icon: "megaphone" },
  { id: "events",        label: "Events",        icon: "calendar"  }
] %}

<nav class="toc" aria-label="Table of contents">
  <div class="toc__title">This Week</div>
  <ul class="toc__list" role="list">
    {% for section in tocSections %}
    <li>
      <a href="#{{ section.id }}" class="toc__link" data-toc-target="{{ section.id }}">
        <i data-lucide="{{ section.icon }}"></i>
        {{ section.label }}
      </a>
    </li>
    {% endfor %}
  </ul>

  {% if prevList and prevList.length %}
  <div class="toc__title" style="margin-top: var(--space-5);">Past Bulletins</div>
  <ul class="toc__list" role="list">
    {% for item in prevList %}
    <li>
      <a href="/previous/{{ item.date }}/" class="toc__link">
        <i data-lucide="file-text"></i>
        <span style="font-size: 11px;">{{ item.date | readableDate }}</span>
      </a>
    </li>
    {% endfor %}
    <li>
      <a href="/previous/" class="toc__link">
        <i data-lucide="archive"></i>
        All bulletins
      </a>
    </li>
  </ul>
  {% endif %}
</nav>
